# ============================================================
#  同频 Resonance · 后端环境变量
#  复制为 .env 后填写。两套标准接口任选其一启用（LLM_PROVIDER 切换）。
# ============================================================

# 选用哪套标准接口： anthropic | openai
LLM_PROVIDER=anthropic

# --- Anthropic 标准接口 ---
ANTHROPIC_API_KEY=
# 推荐 claude-opus-4-8（最有人味）；嫌慢可换 claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI 标准接口（也兼容任何 OpenAI 兼容端点，配 OPENAI_BASE_URL 即可）---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# 允许的前端来源（部署时填 Vercel 域名；本地可留 *）
FRONTEND_ORIGIN=*
